{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "API: IDE 준비",
      "type": "shell",
      "command": "./gradlew prepareIde",
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "group": "build",
      "problemMatcher": "$javac"
    },
    {
      "label": "API: Spotless 적용",
      "type": "shell",
      "command": "./gradlew spotlessApply",
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "problemMatcher": []
    }
  ]
}
