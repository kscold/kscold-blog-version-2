{
  "name": "@kscold-blog/web",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:e2e": "NEXT_PUBLIC_GTM_ID= NEXT_PUBLIC_GA_ID= next dev -p 3101",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "next typegen && tsc --noEmit",
    "cy:open": "unset ELECTRON_RUN_AS_NODE && cypress open",
    "cy:run": "unset ELECTRON_RUN_AS_NODE && cypress run",
    "cy:run:e2e": "unset ELECTRON_RUN_AS_NODE && cypress run --config baseUrl=http://127.0.0.1:3101",
    "test:e2e": "start-server-and-test dev:e2e http://127.0.0.1:3101 cy:run:e2e"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tiptap/extension-bubble-menu": "^3.20.2",
    "@tiptap/extension-code-block-lowlight": "^3.20.2",
    "@tiptap/extension-image": "^3.20.2",
    "@tiptap/extension-link": "^3.20.2",
    "@tiptap/extension-placeholder": "^3.20.2",
    "@tiptap/pm": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "axios": "^1.7.9",
    "d3-force": "^3.0.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.17",
    "gray-matter": "^4.0.3",
    "lowlight": "^3.3.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "react-use": "^17.6.0",
    "remark-gfm": "^4.0.0",
    "socket.io-client": "^4.8.1",
    "tiptap-markdown": "^0.9.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.20",
    "cypress": "^15.4.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "start-server-and-test": "^2.1.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
